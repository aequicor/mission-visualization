{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aequicor.io/schemas/ui-document.schema.json",
  "title": "Mission Visualization UI Document",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "screens"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "theme": { "$ref": "#/$defs/theme" },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/screen" }
    },
    "scenarios": {
      "type": "array",
      "items": { "$ref": "#/$defs/scenario" }
    },
    "comments": {
      "type": "array",
      "items": { "$ref": "#/$defs/comment" }
    },
    "prompts": {
      "type": "array",
      "items": { "$ref": "#/$defs/prompt" }
    }
  },
  "$defs": {
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "primary": { "type": "string" },
        "accent": { "type": "string" },
        "surface": { "type": "string" },
        "mood": { "type": "string" },
        "tokens": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "layout": { "$ref": "#/$defs/layout" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "screen",
            "section",
            "box",
            "text",
            "button",
            "input",
            "form",
            "card",
            "list",
            "tabs",
            "imagePlaceholder",
            "dataTable",
            "dialog",
            "sidebar",
            "timeline",
            "badge",
            "menu",
            "topBar",
            "bottomBar",
            "emptyState"
          ]
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "body": { "type": "string" },
        "placeholder": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "headers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rows": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layout": { "$ref": "#/$defs/layout" },
        "style": { "$ref": "#/$defs/style" },
        "action": { "$ref": "#/$defs/action" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["column", "row", "grid", "stack"] },
        "padding": { "enum": ["none", "xs", "sm", "md", "lg", "xl"] },
        "gap": { "enum": ["none", "xs", "sm", "md", "lg", "xl"] },
        "width": { "enum": ["fill", "hug", "auto", "content"] },
        "height": { "enum": ["fill", "hug", "auto", "content"] },
        "weight": { "type": "number" },
        "align": { "enum": ["start", "center", "end", "stretch", "spaceBetween"] },
        "columns": { "type": "integer", "minimum": 1 }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tone": { "enum": ["neutral", "primary", "accent", "info", "success", "warning", "danger"] },
        "variant": { "enum": ["primary", "secondary", "outline", "ghost", "filled", "tonal"] },
        "size": { "enum": ["xs", "sm", "md", "lg", "xl"] },
        "emphasis": { "enum": ["low", "medium", "high"] },
        "color": { "type": "string" },
        "background": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["none", "navigate", "select", "submit", "openDialog", "closeDialog"] },
        "target": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "steps"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/scenarioStep" }
        }
      }
    },
    "scenarioStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screenId", "action"],
      "properties": {
        "id": { "type": "string" },
        "screenId": { "type": "string" },
        "nodeId": { "type": "string" },
        "action": { "type": "string" },
        "expectation": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "comment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "body"],
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "author": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "body"],
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  }
}
